# =============================================================================
# .env.example
# Copy this file to .env and fill in your actual values
# =============================================================================

BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username
ADMIN_IDS=your_telegram_user_id
POSTGRES_USER=botadmin
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_DB=telegram_bot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://botadmin:superadmin:supersecretpassword@postgres:5432/telegram_bot
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redissecretpassword
REDIS_URL=redis://:redissecretpassword@redis:6379/0
SECRET_KEY=your_super_secret_key_change_this
DOMAIN=yourdomain.com
WEB_PORT=8000
TELEGRAM_LOGIN_BOT_TOKEN=your_bot_token_here
DEBUG=false
LOG_LEVEL=INFO
TIMEZONE=UTC
